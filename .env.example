# GEMINI_API_KEY: Required for Gemini visual analysis in serverless functions.
# The VITE_ prefix exposes it to the client; serverless functions check both.
VITE_GEMINI_API_KEY="MY_GEMINI_API_KEY"

# ANTHROPIC_API_KEY: Required for Claude AI calls in serverless functions.
# Set as ANTHROPIC_API_KEY or VITE_ANTHROPIC_API_KEY — serverless functions check both.
VITE_ANTHROPIC_API_KEY="MY_ANTHROPIC_API_KEY"

# Stripe — Pro tier ($29/month)
# Create: Stripe Dashboard → Products → Cutsheet Pro → Payment Links
# Set success URL: https://cutsheet.xyz/checkout/success
VITE_STRIPE_PRO_PAYMENT_LINK="https://buy.stripe.com/..."

# Stripe — Team tier ($49/month, 3 seats)
# Create: Stripe Dashboard → Products → Cutsheet Team → Payment Links
VITE_STRIPE_TEAM_PAYMENT_LINK="https://buy.stripe.com/..."

# Server-only — Stripe secret key (never expose to client)
STRIPE_SECRET_KEY="sk_test_..."

# Server-only — Signing secret from Stripe Dashboard → Webhooks → [endpoint] → Signing secret
# Events: checkout.session.completed, customer.subscription.deleted, customer.subscription.updated
STRIPE_WEBHOOK_SECRET="whsec_..."

# Server-only — Price IDs from Stripe Dashboard → Products → [product] → Pricing
# Used in stripe-webhook.ts to differentiate Pro vs Team on checkout
STRIPE_PRO_PRICE_ID="price_..."
STRIPE_TEAM_PRICE_ID="price_..."

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# SUPABASE: Required for public shareable links
# Get both from Supabase Dashboard → your project → Settings → API
# - Project URL → VITE_SUPABASE_URL
# - anon public key (long JWT starting with eyJ) → VITE_SUPABASE_ANON_KEY
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_ANON_KEY="your-anon-key"
