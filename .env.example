# ── Server-only API keys (NEVER prefix with VITE_ in production) ──────────────
# These are used by serverless functions only. The VITE_ prefix exposes vars
# to the client JS bundle — only use VITE_ if you need local dev to work via Vite.

GEMINI_API_KEY="MY_GEMINI_API_KEY"
ANTHROPIC_API_KEY="MY_ANTHROPIC_API_KEY"

# ── CORS ──────────────────────────────────────────────────────────────────────
# Set to http://localhost:3000 for local dev, https://cutsheet.xyz in production
ALLOWED_ORIGIN="http://localhost:3000"

# ── Stripe ────────────────────────────────────────────────────────────────────
# Payment links (client-facing, VITE_ prefix is correct here)
VITE_STRIPE_PRO_PAYMENT_LINK="https://buy.stripe.com/..."
VITE_STRIPE_TEAM_PAYMENT_LINK="https://buy.stripe.com/..."

# Server-only — Stripe secret key (never expose to client)
STRIPE_SECRET_KEY="sk_test_..."

# Server-only — Signing secret from Stripe Dashboard → Webhooks → [endpoint] → Signing secret
# Events: checkout.session.completed, customer.subscription.deleted, customer.subscription.updated
STRIPE_WEBHOOK_SECRET="whsec_..."

# Server-only — Price IDs from Stripe Dashboard → Products → [product] → Pricing
# Used in stripe-webhook.ts to differentiate Pro vs Team on checkout
STRIPE_PRO_PRICE_ID="price_..."
STRIPE_TEAM_PRICE_ID="price_..."

# ── Supabase ──────────────────────────────────────────────────────────────────
# Get from: Supabase Dashboard → Settings → API
# Project URL + anon public key (client-facing, VITE_ prefix is correct)
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_ANON_KEY="your-anon-key"

# Server-only — NEVER expose this to the client or prefix with VITE_
# Get from: Supabase Dashboard → Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY="eyJ..."

# ── App URL ───────────────────────────────────────────────────────────────────
APP_URL="http://localhost:3000"
